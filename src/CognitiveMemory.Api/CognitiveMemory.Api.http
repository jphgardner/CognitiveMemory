@base = http://localhost:5008

GET {{base}}/api/v1/memory/health

###
GET {{base}}/api/v1/memory/claims

###
POST {{base}}/api/v1/ingest
Content-Type: application/json

{
  "sourceType": "ChatTurn",
  "sourceRef": "conv:123/turn:5",
  "content": "We switched to SignalR.",
  "metadata": {
    "project": "PokemonMMO"
  }
}

###
POST {{base}}/api/v1/query
Content-Type: application/json

{
  "text": "What transport did we choose?",
  "filters": {
    "subject": "project"
  },
  "topK": 10,
  "includeEvidence": true,
  "includeContradictions": true
}

###
POST {{base}}/api/v1/answer
Content-Type: application/json

{
  "question": "What did we decide?",
  "context": {
    "project": "PokemonMMO"
  }
}

###
GET {{base}}/v1/models
Authorization: Bearer local-dev-key

###
POST {{base}}/v1/chat/completions
Authorization: Bearer local-dev-key
Content-Type: application/json

{
  "model": "cognitivememory-chat",
  "messages": [
    { "role": "system", "content": "You are helpful." },
    { "role": "user", "content": "What did we decide?" }
  ],
  "stream": false
}
