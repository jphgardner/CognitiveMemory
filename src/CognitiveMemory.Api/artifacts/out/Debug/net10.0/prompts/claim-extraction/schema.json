{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["claims"],
  "properties": {
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["predicate", "confidence", "evidenceSummary"],
        "properties": {
          "subjectKey": { "type": ["string", "null"], "minLength": 1 },
          "subjectName": { "type": ["string", "null"] },
          "subjectType": { "type": ["string", "null"] },
          "predicate": { "type": "string", "minLength": 1 },
          "literalValue": { "type": ["string", "null"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidenceSummary": { "type": "string", "minLength": 1, "maxLength": 320 }
        }
      }
    }
  }
}
