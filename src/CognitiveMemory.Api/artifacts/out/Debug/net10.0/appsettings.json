{
  "SemanticKernel": {
    "Provider": "Ollama",
    "OllamaEndpoint": "http://localhost:11434",
    "ChatModelId": "gpt-oss",
    "LoopModelId": "llama3.2:3b",
    "ClaimExtractionModelId": "llama3.2:3b",
    "ChatResponseTimeoutSeconds": 180
  },
  "WorkingMemory": {
    "TtlSeconds": 1800,
    "KeyPrefix": "working-memory:session:"
  },
  "SemanticKernelTooling": {
    "EnableMemoryTools": true,
    "AutoInvokeTools": true,
    "PluginName": "MemoryTools"
  },
  "ConsolidationWorker": {
    "Enabled": true,
    "IntervalSeconds": 30
  },
  "Consolidation": {
    "LookbackHours": 24,
    "MaxCandidatesPerRun": 500,
    "MinExtractionConfidence": 0.6,
    "MinOccurrencesForPromotion": 1
  },
  "DecayWorker": {
    "Enabled": true,
    "IntervalMinutes": 60,
    "StaleDays": 30,
    "DecayStep": 0.05,
    "MinConfidence": 0.2
  },
  "Reasoning": {
    "LookbackHours": 48,
    "MaxEpisodesScanned": 600,
    "MaxClaimsScanned": 500,
    "MinPatternOccurrences": 2,
    "BaseInferenceConfidence": 0.55,
    "ConfidenceStepPerOccurrence": 0.08,
    "MaxInferredConfidence": 0.95,
    "MinConfidenceDeltaForAdjustment": 0.08,
    "WeakClaimThreshold": 0.4,
    "SuggestProceduralPatterns": true
  },
  "ReasoningWorker": {
    "Enabled": true,
    "IntervalMinutes": 20
  },
  "Planning": {
    "DefaultLookbackDays": 30,
    "MaxEpisodesScanned": 500,
    "MaxSupportingSignals": 12,
    "PersistPlansToEpisodicMemory": true,
    "AutoUpdateProceduralMemoryOnSuccess": true
  },
  "IdentityEvolution": {
    "LookbackDays": 45,
    "MaxEpisodesScanned": 700,
    "MinSignalOccurrences": 3,
    "FocusPreferenceKey": "identity.project_focus",
    "StylePreferenceKey": "identity.collaboration_style",
    "GoalPreferenceKey": "identity.long_term_goal"
  },
  "IdentityEvolutionWorker": {
    "Enabled": true,
    "IntervalMinutes": 60
  },
  "TruthMaintenance": {
    "MaxClaimsScanned": 600,
    "ConflictConfidencePenalty": 0.1,
    "UncertainThreshold": 0.45,
    "MinConfidenceDeltaForAdjustment": 0.05,
    "MaxConflictPairsPerRun": 20
  },
  "TruthMaintenanceWorker": {
    "Enabled": true,
    "IntervalMinutes": 45
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "StackExchange.Redis": "Warning",
      "CognitiveMemory.Retrieval": "Information",
      "CognitiveMemory.Scoring": "Information",
      "CognitiveMemory.Debate": "Information",
      "CognitiveMemory.Conscience": "Information",
      "CognitiveMemory.Api.Middleware.RequestContextLoggingMiddleware": "Information"
    }
  }
}
