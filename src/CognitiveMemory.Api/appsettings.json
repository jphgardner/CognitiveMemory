{
  "SemanticKernel": {
    "Provider": "InMemory",
    "ChatModelId": "gpt-4o-mini",
    "EmbeddingModelId": "text-embedding-3-small",
    "ConscienceAnalysisTimeoutSeconds": 25
  },
  "QueryCache": {
    "TtlSeconds": 120
  },
  "AgentTooling": {
    "Mode": "ReadOnly",
    "MaxToolCallsPerRequest": 16,
    "ToolTimeoutSeconds": 10
  },
  "ChatPersistence": {
    "Mode": "AgentOnly",
    "IngestAssistantTurns": false
  },
  "ConscienceOutboxWorker": {
    "PollIntervalSeconds": 3,
    "BatchSize": 24,
    "LeaseSeconds": 30,
    "RetryDelaySeconds": 20
  },
  "ConscienceCalibration": {
    "EnableClaimConfidenceWriteBack": true,
    "MaxRiskScoreForWriteBack": 0.7,
    "MinDeltaToWriteBack": 0.05,
    "MaxStepPerUpdate": 0.2,
    "AllowedDecisions": [
      "Approve",
      "Downgrade",
      "Revise"
    ]
  },
  "OpenAiCompat": {
    "Enabled": true,
    "RequireApiKey": false,
    "AllowAnyNonEmptyApiKey": true,
    "DefaultModel": "cognitivememory-chat",
    "Models": [
      "cognitivememory-chat",
      "cognitivememory-fast",
      "cognitivememory-answer"
    ],
    "ExposeEmbeddings": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "StackExchange.Redis": "Warning",
      "CognitiveMemory.Retrieval": "Information",
      "CognitiveMemory.Scoring": "Information",
      "CognitiveMemory.Debate": "Information",
      "CognitiveMemory.Conscience": "Information",
      "CognitiveMemory.Api.Middleware.RequestContextLoggingMiddleware": "Information"
    }
  }
}
